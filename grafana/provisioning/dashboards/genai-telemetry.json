{
  "uid": "genai-telemetry",
  "title": "GenAI Telemetry",
  "tags": ["genai", "langchain4j", "llm"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "LLM Call Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(gen_ai_client_operation_duration_seconds_count[1m])",
          "legendFormat": "{{job}} - {{gen_ai_operation_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 2,
      "title": "LLM Call Latency (p95)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(gen_ai_client_operation_duration_seconds_bucket[5m]))",
          "legendFormat": "{{job}} p95"
        },
        {
          "expr": "histogram_quantile(0.50, rate(gen_ai_client_operation_duration_seconds_bucket[5m]))",
          "legendFormat": "{{job}} p50"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 3,
      "title": "Input Tokens Used",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(gen_ai_client_token_usage_total{gen_ai_token_type=\"input\"}[5m])",
          "legendFormat": "{{job}} input tokens/s"
        }
      ]
    },
    {
      "id": 4,
      "title": "Output Tokens Used",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(gen_ai_client_token_usage_total{gen_ai_token_type=\"output\"}[5m])",
          "legendFormat": "{{job}} output tokens/s"
        }
      ]
    },
    {
      "id": 5,
      "title": "Total Tokens (cumulative)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(gen_ai_client_token_usage_total)",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 6,
      "title": "LLM Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 16, "w": 16, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(gen_ai_client_operation_duration_seconds_count{error_type!=\"\"}[5m])",
          "legendFormat": "{{job}} errors/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "red", "mode": "fixed" } }
      }
    },
    {
      "id": 7,
      "title": "LLM Traces",
      "type": "traces",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 10 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "queryType": "traceql",
          "query": "{span.gen_ai.system=\"openai\"}"
        }
      ]
    }
  ]
}
